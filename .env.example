# Required — bot token from Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token

# Required — Application ID from Discord Developer Portal (General Information → Application ID)
CLIENT_ID=your_application_client_id

# Recommended — set this for instant command registration during development.
# Without it, `npm run deploy` registers global commands which take up to 1 hour.
# `npm run deploy:guild` will fail if this is not set.
GUILD_ID=your_guild_id

# Optional — Redis URL for persistent caching (tempbans survive restarts).
# Falls back to in-memory cache if not set.
REDIS_URL=redis://127.0.0.1:6379
