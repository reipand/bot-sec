{
  "name": "discord-security-bot",
  "version": "2.0.0",
  "description": "Production-ready Discord security & moderation bot with slash commands.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy": "node scripts/deploy-commands.js",
    "deploy:guild": "node scripts/deploy-commands.js --guild-only",
    "deploy:clear": "node scripts/deploy-commands.js --clear",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop discord-security-bot",
    "pm2:restart": "pm2 restart discord-security-bot",
    "pm2:reload": "pm2 reload discord-security-bot",
    "pm2:logs": "pm2 logs discord-security-bot",
    "pm2:status": "pm2 status"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1"
  }
}
